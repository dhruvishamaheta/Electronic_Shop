<?xml version="1.0" encoding="utf-8"?>
<!--
Application rebuilt: 2025-12-26
Added ProductDetails.aspx page with product details and related products feature
-->
<configuration>

	<!-- Database connection -->
	<connectionStrings>
		<add name="es"
			 connectionString="Data Source=(LocalDB)\MSSQLLocalDB;AttachDbFilename=|DataDirectory|\electronic_shop.mdf;Integrated Security=True"
			 providerName="System.Data.SqlClient" />
	</connectionStrings>

	<!-- Application settings -->
	<appSettings>
		<!-- Enable unobtrusive validation (requires jQuery mapping in Global.asax.cs) -->
		<add key="ValidationSettings:UnobtrusiveValidationMode" value="WebForms" />


		<!-- Optional: show detailed errors while debugging -->
		<add key="aspnet:UseTaskFriendlySynchronizationContext" value="true" />
	</appSettings>

	<system.web>
		<!-- Session timeout -->
		<sessionState mode="InProc" timeout="20" />

		<!-- Compilation settings -->
		<compilation debug="true" targetFramework="4.7.2" batch="false" batchTimeout="300" />

		<!-- Runtime settings -->
		<httpRuntime targetFramework="4.7.2" />

		<!-- Optional: show detailed errors during development -->
		<customErrors mode="Off" />
	</system.web>

</configuration>
